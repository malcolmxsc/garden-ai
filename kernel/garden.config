# =====================================================================
# Garden AI — Custom Kernel Config Overrides
# =====================================================================
# These are appended to the default arm64 defconfig. The `olddefconfig`
# pass resolves any dependency conflicts.
#
# Philosophy: CONFIG_MODULES=n means everything needed is built-in.
# No module loading, no modprobe, no /lib/modules/ in initramfs.
# =====================================================================

# --- VirtIO-vSock (THE WHOLE POINT) ---
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y

# --- Core VirtIO (Virtualization.framework devices) ---
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_RNG=y
CONFIG_VIRTIO_BALLOON=y

# --- Networking (needed for DHCP / internet egress) ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y

# --- Filesystem basics ---
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# --- Serial Console (PL011 for Virtualization.framework) ---
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# --- Initramfs support ---
CONFIG_BLK_DEV_INITRD=y

# --- PCI (Virtualization.framework presents devices over PCI) ---
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y

# --- eBPF Security Telemetry ---
# Required for aya-based eBPF probe loading inside the guest VM.
# These enable syscall tracepoints (execve, openat, connect) and
# PerfEventArray for streaming events to userspace.
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_TRACEPOINTS=y
CONFIG_FTRACE=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_PERF_EVENTS=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_PAHOLE_HAS_SPLIT_BTF=y
CONFIG_DEBUG_INFO_DWARF5=y

# --- Disable modules (everything built-in) ---
CONFIG_MODULES=n

# --- Disable unnecessary subsystems for smaller kernel ---
CONFIG_SOUND=n
CONFIG_USB_SUPPORT=n
CONFIG_WLAN=n
CONFIG_BLUETOOTH=n
CONFIG_DRM=n
CONFIG_INPUT_MOUSE=n
CONFIG_WIRELESS=n
CONFIG_HAMRADIO=n
CONFIG_CAN=n
CONFIG_NFC=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_STAGING=n
